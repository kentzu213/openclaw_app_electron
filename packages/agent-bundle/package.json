{
  "name": "@openclaw/agent-bundle",
  "version": "0.1.0",
  "description": "Agent Bundle (.oab) format — package, validate, and install pre-configured AI agent bundles for OpenClaw",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "watch": "tsc --watch",
    "clean": "rimraf dist"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "openclaw",
    "agent",
    "bundle",
    "ai-agent",
    "hermes",
    "automation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.15",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
