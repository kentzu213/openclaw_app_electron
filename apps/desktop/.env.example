# === Supabase Auth (same project as izziapi.com) ===
# Anon key is safe to include — it's public (like izzi-web-v2)
STARIZZI_SUPABASE_URL=https://your-project.supabase.co
STARIZZI_SUPABASE_ANON_KEY=eyJ...your-anon-key

# === API URLs ===
STARIZZI_API_URL=http://localhost:8787
STARIZZI_MARKETPLACE_URL=http://localhost:8788

# Legacy env vars (still supported for backward compat)
# OPENCLAW_SUPABASE_URL=
# OPENCLAW_SUPABASE_ANON_KEY=
# OPENCLAW_API_URL=
