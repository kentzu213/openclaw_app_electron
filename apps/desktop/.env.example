# === Supabase Auth (same project as izziapi.com) ===
# Anon key is safe to include — it's public (like izzi-web-v2)
OPENCLAW_SUPABASE_URL=https://your-project.supabase.co
OPENCLAW_SUPABASE_ANON_KEY=eyJ...your-anon-key

# === API URLs ===
OPENCLAW_API_URL=http://localhost:8787
OPENCLAW_MARKETPLACE_URL=http://localhost:8788
OPENCLAW_AGENT_CHAT_URL=http://localhost:8787/api/agent/chat
OPENCLAW_AGENT_STATUS_URL=http://localhost:8787/api/agent/status
OPENCLAW_INTEGRATIONS_URL=http://localhost:8787/api/integrations

# === Deterministic smoke/mock mode ===
OPENCLAW_MOCK_AGENT_MODE=false
OPENCLAW_MOCK_INTEGRATIONS=false
OPENCLAW_MOCK_UPDATER=false
